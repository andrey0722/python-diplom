# Django secret key. Replace with a unique secret outside local development.
DJANGO_SECRET_KEY=django-example-key

# Enable Django debug tools and local file:// pricing imports.
DJANGO_DEBUG=True

# Comma-separated allowed hosts. Use * only for local development.
DJANGO_ALLOWED_HOSTS=*

# Main database connection URL. Docker Compose overrides it for containers.
DATABASE_URL=postgres://user:password@localhost:5432/database
# DATABASE_URL=sqlite:///db.sqlite3

# Celery broker URL. Redis is used by the bundled Compose configuration.
CELERY_BROKER_URL=redis://default:redis_password@localhost:6379/0

# Celery worker concurrency. 1 is OK for simple local development.
CELERY_WORKER_CONCURRENCY=1

# Email backend URL. Other valid choices are commented out.
EMAIL_URL=filemail:///email
# EMAIL_URL=consolemail://
# EMAIL_URL=smtp://localhost:1025
# EMAIL_URL=smtp+tls://user:password@smtp.example.com:587

# External Nginx proxy port for Docker Compose.
LISTEN_PORT=8080

# Dump SQL queries to DEBUG logs
SQL_TRACE=False
